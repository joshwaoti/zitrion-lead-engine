# ============================================================================
# Zitrion Lead Engine - self-hosted Convex (Dokploy Compose env)
# Copy these into the Dokploy Compose "Environment" tab for the stack.
# Generated strong secrets are pre-filled; CHANGE the domains to your own.
# ============================================================================

# --- Public domains (point these A-records/Traefik to the Dokploy server) ---
# convex-backend (API / client connections)
CONVEX_CLOUD_ORIGIN=https://convex-lead.zitrion.tech
# convex-backend (HTTP actions / site)
CONVEX_SITE_ORIGIN=https://convex-site-lead.zitrion.tech

# --- Convex self-hosted instance ---
INSTANCE_NAME=zitrion-lead-engine
INSTANCE_SECRET=S4LpPA8BUkDq7FncdUXedt1xAoD11skwKHBeJxsVHWJ03HjM
DO_NOT_REQUIRE_SSL=1
DISABLE_METRICS_ENDPOINT=true
DOCUMENT_RETENTION_DELAY=172800
RUST_LOG=info

# --- Postgres (Convex storage backend) ---
POSTGRES_DB=zitrion_lead_engine
POSTGRES_USER=zitrion
POSTGRES_PASSWORD=ozKp0vtnRCwOXLwC8GmH3QrOIrJPDssE
POSTGRES_URL=postgresql://zitrion:ozKp0vtnRCwOXLwC8GmH3QrOIrJPDssE@convex-postgres:5432

# --- Filled AFTER first deploy: read the convex-admin-key service logs ---
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ============================================================================
# App secrets (set on the dashboard/worker apps, NOT the Convex compose):
#   OPENROUTER_API_KEY=...
# ============================================================================
