# =============================================================================
# Zitrion Social Lead Engine - environment variables
# Copy to .env (and configure the same vars in your Convex deployment dashboard /
# Dokploy app environment). NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (client / tooling)
# -----------------------------------------------------------------------------
# Public URL of your (self-hosted) Convex deployment - consumed by the dashboard
# and the Chrome extension to talk to Convex.
CONVEX_URL=https://your-convex-deployment.example.com
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.example.com

# Used by the `convex` CLI when pointing at a self-hosted backend.
# (Managed Convex uses `npx convex dev` login instead.)
CONVEX_SELF_HOSTED_URL=https://your-convex-deployment.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-convex-admin-key
# Alternatively, for managed Convex:
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# -----------------------------------------------------------------------------
# Convex deployment environment variables
# These must be set ON the Convex deployment (Settings -> Environment Variables),
# because the AI pipeline runs server-side inside Convex actions.
# -----------------------------------------------------------------------------

# OpenRouter - powers the AI model gateway (free-model fallback chains).
# Get one at https://openrouter.ai/keys . A small top-up raises the free daily cap.
OPENROUTER_API_KEY=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

# Optional: overrides for OpenRouter attribution headers (recommended by OpenRouter).
OPENROUTER_APP_URL=https://zitrion.com
OPENROUTER_APP_TITLE=Zitrion Lead Engine

# VPS Playwright worker (secondary executor)
WORKER_DEVICE_TOKEN=replace-after-pair-command
WORKER_WORKSPACE_ID=replace-with-workspace-id
REDDIT_USER_DATA_DIR=./.data/reddit-profile
WORKER_POLL_INTERVAL_MS=30000
WORKER_HEADLESS=true
